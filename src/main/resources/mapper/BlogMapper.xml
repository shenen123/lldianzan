<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.liubinrui.mapper.BlogMapper">

    <resultMap id="BaseResultMap" type="com.liubinrui.model.entity.Blog">
        <id property="id" column="id" jdbcType="BIGINT"/>
        <result property="userId" column="user_id" jdbcType="BIGINT"/>
        <result property="title" column="title" jdbcType="VARCHAR"/>
        <result property="content" column="content" jdbcType="VARCHAR"/>
        <result property="thumbCount" column="thumb_count" jdbcType="INTEGER"/>
        <result property="createTime" column="create_time" jdbcType="TIMESTAMP"/>
        <result property="updateTime" column="update_time" jdbcType="TIMESTAMP"/>
    </resultMap>

    <sql id="Base_Column_List">
        id
        ,userId,title,content,thumb_count,
        create_time,update_time
    </sql>

    <update id="addThumb">
        update blog
        set thumb_count=thumb_count + 1
        where id = #{blogId}
    </update>

    <update id="subThumb">
        update blog
        set thumb_count=thumb_count - 1
        where id = #{blogId}
    </update>

    <update id="batchUpdateThumbCount">
        UPDATE blog
        SET thumb_count = thumb_count + CASE id
        <foreach collection="countMap.entrySet()" item="value" index="key">
            WHEN #{key} THEN #{value}
        </foreach>
        END
        WHERE id IN
        <foreach collection="countMap.keySet()" item="id" open="(" separator="," close=")">
            #{id}
        </foreach>
    </update>

    <update id="incrementThumbCount">
        UPDATE blog
        SET thumb_count = GREATEST(thumb_count + #{delta}, 0)
        WHERE id = #{blogId}
        AND thumb_count + #{delta} >= 0; <!-- 可选：提前过滤无效更新 -->
    </update>

    <update id="updateBatchLikeCount">
        update blog
        set thumb_count =
        <foreach collection="list" item="item" separator=" " open="case id" close="end">
            when #{item.id} then #{item.likeCount}
        </foreach>
        where id in
        <foreach collection="list" item="item" open="(" separator="," close=")">
            #{item.id}
        </foreach>
    </update>

    <select id="selectAllblogId" resultType="java.lang.Long">
        SELECT id FROM blog
    </select>
</mapper>
